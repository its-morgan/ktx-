<?php

namespace App\Http\Middleware;

use App\Models\User;
use Closure;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\Auth;
use Symfony\Component\HttpFoundation\Response;

class KiemTraVaiTro
{
    /**
     * Kiem tra vai tro dang nhap theo route middleware.
     */
    public function handle(Request $request, Closure $next, string $vaitrobatbuoc): Response
    {
        if (! Auth::check()) {
            return redirect()->route('login');
        }

        /** @var \App\Models\User $user */
        $user = Auth::user();
        $vaitrohientai = $user->vaitro ?? null;

        $dungVaiTro = match ($vaitrobatbuoc) {
            User::ROLE_ADMIN => $user->isAdminGroup(),
            default => $vaitrohientai === $vaitrobatbuoc,
        };

        if (! $dungVaiTro) {
            return redirect()
                ->route('dashboard')
                ->with('toast_loai', 'loi')
                ->with('toast_noidung', 'Ban khong co quyen truy cap chuc nang nay.');
        }

        return $next($request);
    }
}
